{
  "spring_dockerfile": {
    "prefix": "spring_dockerfile",
    "description": "Multi-stage Dockerfile for Spring Boot",
    "body": [
      "# Build stage",
      "FROM eclipse-temurin:${1:21}-jdk-alpine AS builder",
      "WORKDIR /app",
      "",
      "# Copy maven/gradle files",
      "COPY pom.xml .",
      "COPY .mvn .mvn",
      "COPY mvnw .",
      "",
      "# Download dependencies (cached layer)",
      "RUN chmod +x mvnw && ./mvnw dependency:go-offline -B",
      "",
      "# Copy source and build",
      "COPY src src",
      "RUN ./mvnw package -DskipTests -B",
      "",
      "# Runtime stage",
      "FROM eclipse-temurin:${1}-jre-alpine",
      "WORKDIR /app",
      "",
      "# Create non-root user",
      "RUN addgroup -S spring && adduser -S spring -G spring",
      "USER spring:spring",
      "",
      "# Copy jar from builder",
      "COPY --from=builder /app/target/*.jar app.jar",
      "",
      "# Health check",
      "HEALTHCHECK --interval=30s --timeout=3s --start-period=30s --retries=3 \\\\",
      "    CMD wget --quiet --tries=1 --spider http://localhost:8080/actuator/health || exit 1",
      "",
      "# Run",
      "EXPOSE 8080",
      "ENTRYPOINT [\"java\", \"-jar\", \"app.jar\"]",
      "$0"
    ]
  },
  "spring_dockerfile_gradle": {
    "prefix": "spring_dockerfile_gradle",
    "description": "Dockerfile for Gradle Spring Boot",
    "body": [
      "# Build stage",
      "FROM eclipse-temurin:${1:21}-jdk-alpine AS builder",
      "WORKDIR /app",
      "",
      "COPY gradle gradle",
      "COPY gradlew build.gradle* settings.gradle* ./",
      "",
      "RUN chmod +x gradlew && ./gradlew dependencies --no-daemon",
      "",
      "COPY src src",
      "RUN ./gradlew bootJar --no-daemon",
      "",
      "# Runtime stage",
      "FROM eclipse-temurin:${1}-jre-alpine",
      "WORKDIR /app",
      "",
      "RUN addgroup -S spring && adduser -S spring -G spring",
      "USER spring:spring",
      "",
      "COPY --from=builder /app/build/libs/*.jar app.jar",
      "",
      "EXPOSE 8080",
      "ENTRYPOINT [\"java\", \"-jar\", \"app.jar\"]",
      "$0"
    ]
  },
  "spring_dockerfile_simple": {
    "prefix": "spring_dockerfile_simple",
    "description": "Simple Dockerfile (pre-built jar)",
    "body": [
      "FROM eclipse-temurin:${1:21}-jre-alpine",
      "WORKDIR /app",
      "",
      "RUN addgroup -S spring && adduser -S spring -G spring",
      "USER spring:spring",
      "",
      "COPY target/*.jar app.jar",
      "",
      "EXPOSE 8080",
      "ENTRYPOINT [\"java\", \"-jar\", \"app.jar\"]",
      "$0"
    ]
  }
}
