  "pattern_command": {
    "prefix": "pattern_command",
    "description": "Command Pattern",
    "body": [
      "package ${1:com.example.${2:app}}.command;",
      "",
      "import java.util.Stack;",
      "",
      "// Command Interface",
      "public interface ${TM_FILENAME_BASE} {",
      "    void execute();",
