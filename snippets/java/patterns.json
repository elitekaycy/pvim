      "    public Concrete${TM_FILENAME_BASE}(${3} receiver) {",
      "        this.receiver = receiver;",
      "    }",
      "",
      "    @Override",
      "    public void execute() {",
      "        previousState = receiver.getState();",
      "        receiver.action();",
      "    }",
      "",
      "    @Override",
      "    public void undo() {",
      "        receiver.setState(previousState);",
      "    }",
      "}",
      "",
      "// Invoker with undo support",
      "class ${TM_FILENAME_BASE}Invoker {",
      "    private final Stack<${TM_FILENAME_BASE}> history = new Stack<>();",
      "",
      "    public void execute(${TM_FILENAME_BASE} command) {",
      "        command.execute();",
      "        history.push(command);",
      "    }",
      "",
      "    public void undo() {",
      "        if (!history.isEmpty()) {",
      "            history.pop().undo();",
      "        }",
      "    }",
      "}",
      "$0"
    ]
  },
