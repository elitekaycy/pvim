      "        observers.add(observer);",
      "    }",
      "",
      "    public void detach(${TM_FILENAME_BASE} observer) {",
      "        observers.remove(observer);",
      "    }",
      "",
      "    public void setState(${3} state) {",
      "        this.state = state;",
      "        notifyObservers();",
      "    }",
      "",
      "    private void notifyObservers() {",
      "        observers.forEach(o -> o.update(state));",
      "    }",
      "}",
      "",
      "// Concrete Observer",
      "class Concrete${TM_FILENAME_BASE} implements ${TM_FILENAME_BASE} {",
      "    private final String name;",
