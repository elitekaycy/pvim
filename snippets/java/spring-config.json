{
  "spring_config": {
    "prefix": "spring_config",
    "description": "Configuration class",
    "body": [
      "package ${1:com.example.${2:app}}.config;",
      "",
      "import org.springframework.context.annotation.Bean;",
      "import org.springframework.context.annotation.Configuration;",
      "",
      "@Configuration",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    @Bean",
      "    public ${3:Object} ${4:beanName}() {",
      "        return new ${3}();",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_config_security": {
    "prefix": "spring_config_security",
    "description": "Security Configuration",
    "body": [
      "package ${1:com.example.${2:app}}.config;",
      "",
      "import org.springframework.context.annotation.Bean;",
      "import org.springframework.context.annotation.Configuration;",
      "import org.springframework.security.config.annotation.web.builders.HttpSecurity;",
      "import org.springframework.security.config.annotation.web.configuration.EnableWebSecurity;",
      "import org.springframework.security.config.http.SessionCreationPolicy;",
      "import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;",
      "import org.springframework.security.crypto.password.PasswordEncoder;",
      "import org.springframework.security.web.SecurityFilterChain;",
      "",
      "@Configuration",
      "@EnableWebSecurity",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    @Bean",
      "    public SecurityFilterChain securityFilterChain(HttpSecurity http) throws Exception {",
      "        http",
      "            .csrf(csrf -> csrf.disable())",
      "            .sessionManagement(s -> s.sessionCreationPolicy(SessionCreationPolicy.STATELESS))",
      "            .authorizeHttpRequests(auth -> auth",
      "                .requestMatchers(\"/api/auth/**\", \"/api/public/**\").permitAll()",
      "                .requestMatchers(\"/api/admin/**\").hasRole(\"ADMIN\")",
      "                .anyRequest().authenticated()",
      "            );",
      "        return http.build();",
      "    }",
      "",
      "    @Bean",
      "    public PasswordEncoder passwordEncoder() {",
      "        return new BCryptPasswordEncoder();",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_config_cors": {
    "prefix": "spring_config_cors",
    "description": "CORS Configuration",
    "body": [
      "package ${1:com.example.${2:app}}.config;",
      "",
      "import org.springframework.context.annotation.Bean;",
      "import org.springframework.context.annotation.Configuration;",
      "import org.springframework.web.cors.CorsConfiguration;",
      "import org.springframework.web.cors.CorsConfigurationSource;",
      "import org.springframework.web.cors.UrlBasedCorsConfigurationSource;",
      "",
      "import java.util.Arrays;",
      "import java.util.List;",
      "",
      "@Configuration",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    @Bean",
      "    public CorsConfigurationSource corsConfigurationSource() {",
      "        CorsConfiguration config = new CorsConfiguration();",
      "        config.setAllowedOrigins(List.of(\"${3:http://localhost:3000}\"));",
      "        config.setAllowedMethods(Arrays.asList(\"GET\", \"POST\", \"PUT\", \"DELETE\", \"PATCH\"));",
      "        config.setAllowedHeaders(Arrays.asList(\"Authorization\", \"Content-Type\"));",
      "        config.setAllowCredentials(true);",
      "",
      "        UrlBasedCorsConfigurationSource source = new UrlBasedCorsConfigurationSource();",
      "        source.registerCorsConfiguration(\"/api/**\", config);",
      "        return source;",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_config_swagger": {
    "prefix": "spring_config_swagger",
    "description": "OpenAPI/Swagger Configuration",
    "body": [
      "package ${1:com.example.${2:app}}.config;",
      "",
      "import io.swagger.v3.oas.models.OpenAPI;",
      "import io.swagger.v3.oas.models.info.Contact;",
      "import io.swagger.v3.oas.models.info.Info;",
      "import io.swagger.v3.oas.models.info.License;",
      "import org.springframework.context.annotation.Bean;",
      "import org.springframework.context.annotation.Configuration;",
      "",
      "@Configuration",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    @Bean",
      "    public OpenAPI customOpenAPI() {",
      "        return new OpenAPI()",
      "                .info(new Info()",
      "                        .title(\"${3:API Title}\")",
      "                        .version(\"${4:1.0}\")",
      "                        .description(\"${5:API Description}\")",
      "                        .contact(new Contact()",
      "                                .name(\"${6:Your Name}\")",
      "                                .email(\"${7:email@example.com}\"))",
      "                        .license(new License()",
      "                                .name(\"MIT\")));",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_config_async": {
    "prefix": "spring_config_async",
    "description": "Async Configuration",
    "body": [
      "package ${1:com.example.${2:app}}.config;",
      "",
      "import org.springframework.context.annotation.Bean;",
      "import org.springframework.context.annotation.Configuration;",
      "import org.springframework.scheduling.annotation.EnableAsync;",
      "import org.springframework.scheduling.concurrent.ThreadPoolTaskExecutor;",
      "",
      "import java.util.concurrent.Executor;",
      "",
      "@Configuration",
      "@EnableAsync",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    @Bean(name = \"taskExecutor\")",
      "    public Executor taskExecutor() {",
      "        ThreadPoolTaskExecutor executor = new ThreadPoolTaskExecutor();",
      "        executor.setCorePoolSize(${3:4});",
      "        executor.setMaxPoolSize(${4:8});",
      "        executor.setQueueCapacity(${5:100});",
      "        executor.setThreadNamePrefix(\"Async-\");",
      "        executor.initialize();",
      "        return executor;",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_config_cache": {
    "prefix": "spring_config_cache",
    "description": "Cache Configuration",
    "body": [
      "package ${1:com.example.${2:app}}.config;",
      "",
      "import org.springframework.cache.CacheManager;",
      "import org.springframework.cache.annotation.EnableCaching;",
      "import org.springframework.cache.concurrent.ConcurrentMapCacheManager;",
      "import org.springframework.context.annotation.Bean;",
      "import org.springframework.context.annotation.Configuration;",
      "",
      "@Configuration",
      "@EnableCaching",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    @Bean",
      "    public CacheManager cacheManager() {",
      "        return new ConcurrentMapCacheManager(\"${3:cacheName}\");",
      "    }",
      "}",
      "$0"
    ]
  }
}
