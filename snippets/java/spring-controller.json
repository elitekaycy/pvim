{
  "spring_controller": {
    "prefix": "spring_controller",
    "description": "REST Controller with CRUD",
    "body": [
      "package ${1:com.example.${2:app}}.controller;",
      "",
      "import ${1}.dto.${3:Entity}Dto;",
      "import ${1}.service.${3}Service;",
      "import jakarta.validation.Valid;",
      "import org.springframework.http.HttpStatus;",
      "import org.springframework.http.ResponseEntity;",
      "import org.springframework.web.bind.annotation.*;",
      "",
      "import java.util.List;",
      "",
      "@RestController",
      "@RequestMapping(\"/api/${4:${3/(.*)/${1:/downcase}/}}s\")",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    private final ${3}Service service;",
      "",
      "    public ${TM_FILENAME_BASE}(${3}Service service) {",
      "        this.service = service;",
      "    }",
      "",
      "    @GetMapping",
      "    public ResponseEntity<List<${3}Dto>> getAll() {",
      "        return ResponseEntity.ok(service.findAll());",
      "    }",
      "",
      "    @GetMapping(\"/{id}\")",
      "    public ResponseEntity<${3}Dto> getById(@PathVariable Long id) {",
      "        return ResponseEntity.ok(service.findById(id));",
      "    }",
      "",
      "    @PostMapping",
      "    public ResponseEntity<${3}Dto> create(@Valid @RequestBody ${3}Dto dto) {",
      "        return ResponseEntity.status(HttpStatus.CREATED).body(service.create(dto));",
      "    }",
      "",
      "    @PutMapping(\"/{id}\")",
      "    public ResponseEntity<${3}Dto> update(@PathVariable Long id, @Valid @RequestBody ${3}Dto dto) {",
      "        return ResponseEntity.ok(service.update(id, dto));",
      "    }",
      "",
      "    @DeleteMapping(\"/{id}\")",
      "    public ResponseEntity<Void> delete(@PathVariable Long id) {",
      "        service.delete(id);",
      "        return ResponseEntity.noContent().build();",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_controller_lombok": {
    "prefix": "spring_controller_lombok",
    "description": "REST Controller with Lombok",
    "body": [
      "package ${1:com.example.${2:app}}.controller;",
      "",
      "import ${1}.dto.${3:Entity}Dto;",
      "import ${1}.service.${3}Service;",
      "import jakarta.validation.Valid;",
      "import lombok.RequiredArgsConstructor;",
      "import org.springframework.http.HttpStatus;",
      "import org.springframework.http.ResponseEntity;",
      "import org.springframework.web.bind.annotation.*;",
      "",
      "import java.util.List;",
      "",
      "@RestController",
      "@RequestMapping(\"/api/${4:${3/(.*)/${1:/downcase}/}}s\")",
      "@RequiredArgsConstructor",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    private final ${3}Service service;",
      "",
      "    @GetMapping",
      "    public ResponseEntity<List<${3}Dto>> getAll() {",
      "        return ResponseEntity.ok(service.findAll());",
      "    }",
      "",
      "    @GetMapping(\"/{id}\")",
      "    public ResponseEntity<${3}Dto> getById(@PathVariable Long id) {",
      "        return ResponseEntity.ok(service.findById(id));",
      "    }",
      "",
      "    @PostMapping",
      "    public ResponseEntity<${3}Dto> create(@Valid @RequestBody ${3}Dto dto) {",
      "        return ResponseEntity.status(HttpStatus.CREATED).body(service.create(dto));",
      "    }",
      "",
      "    @PutMapping(\"/{id}\")",
      "    public ResponseEntity<${3}Dto> update(@PathVariable Long id, @Valid @RequestBody ${3}Dto dto) {",
      "        return ResponseEntity.ok(service.update(id, dto));",
      "    }",
      "",
      "    @DeleteMapping(\"/{id}\")",
      "    public ResponseEntity<Void> delete(@PathVariable Long id) {",
      "        service.delete(id);",
      "        return ResponseEntity.noContent().build();",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_controller_pageable": {
    "prefix": "spring_controller_pageable",
    "description": "Controller with pagination",
    "body": [
      "@GetMapping",
      "public ResponseEntity<Page<${1:Entity}Dto>> getAll(",
      "        @RequestParam(defaultValue = \"0\") int page,",
      "        @RequestParam(defaultValue = \"10\") int size,",
      "        @RequestParam(defaultValue = \"id\") String sortBy,",
      "        @RequestParam(defaultValue = \"asc\") String sortDir) {",
      "    Sort sort = sortDir.equalsIgnoreCase(\"asc\") ? Sort.by(sortBy).ascending() : Sort.by(sortBy).descending();",
      "    Pageable pageable = PageRequest.of(page, size, sort);",
      "    return ResponseEntity.ok(service.findAll(pageable));",
      "}",
      "$0"
    ]
  },
  "spring_controller_endpoint": {
    "prefix": "spring_controller_endpoint",
    "description": "Single controller endpoint",
    "body": [
      "@${1|GetMapping,PostMapping,PutMapping,DeleteMapping,PatchMapping|}(\"${2:/path}\")",
      "public ResponseEntity<${3:Object}> ${4:methodName}(${5:@RequestBody ${3} request}) {",
      "    $0",
      "    return ResponseEntity.ok(${6:result});",
      "}"
    ]
  }
}
