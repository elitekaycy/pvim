{
  "spring_test_unit": {
    "prefix": "spring_test_unit",
    "description": "Unit Test with Mockito",
    "body": [
      "package ${1:com.example.${2:app}}.service;",
      "",
      "import ${1}.dto.${3:Entity}Dto;",
      "import ${1}.entity.${3};",
      "import ${1}.mapper.${3}Mapper;",
      "import ${1}.repository.${3}Repository;",
      "import org.junit.jupiter.api.BeforeEach;",
      "import org.junit.jupiter.api.Test;",
      "import org.junit.jupiter.api.DisplayName;",
      "import org.junit.jupiter.api.extension.ExtendWith;",
      "import org.mockito.InjectMocks;",
      "import org.mockito.Mock;",
      "import org.mockito.junit.jupiter.MockitoExtension;",
      "",
      "import java.util.Optional;",
      "import java.util.List;",
      "",
      "import static org.assertj.core.api.Assertions.*;",
      "import static org.mockito.ArgumentMatchers.any;",
      "import static org.mockito.Mockito.*;",
      "",
      "@ExtendWith(MockitoExtension.class)",
      "class ${TM_FILENAME_BASE} {",
      "",
      "    @Mock",
      "    private ${3}Repository repository;",
      "",
      "    @Mock",
      "    private ${3}Mapper mapper;",
      "",
      "    @InjectMocks",
      "    private ${3}Service service;",
      "",
      "    private ${3} entity;",
      "    private ${3}Dto dto;",
      "",
      "    @BeforeEach",
      "    void setUp() {",
      "        entity = new ${3}();",
      "        entity.setId(1L);",
      "",
      "        dto = new ${3}Dto();",
      "        dto.setId(1L);",
      "    }",
      "",
      "    @Test",
      "    @DisplayName(\"Should find ${3} by ID\")",
      "    void findById_Success() {",
      "        when(repository.findById(1L)).thenReturn(Optional.of(entity));",
      "        when(mapper.toDto(any())).thenReturn(dto);",
      "",
      "        ${3}Dto result = service.findById(1L);",
      "",
      "        assertThat(result).isNotNull();",
      "        assertThat(result.getId()).isEqualTo(1L);",
      "        verify(repository).findById(1L);",
      "    }",
      "",
      "    @Test",
      "    @DisplayName(\"Should throw when ${3} not found\")",
      "    void findById_NotFound() {",
      "        when(repository.findById(1L)).thenReturn(Optional.empty());",
      "",
      "        assertThatThrownBy(() -> service.findById(1L))",
      "                .isInstanceOf(RuntimeException.class);",
      "    }",
      "",
      "    @Test",
      "    @DisplayName(\"Should create ${3}\")",
      "    void create_Success() {",
      "        when(mapper.toEntity(any())).thenReturn(entity);",
      "        when(repository.save(any())).thenReturn(entity);",
      "        when(mapper.toDto(any())).thenReturn(dto);",
      "",
      "        ${3}Dto result = service.create(dto);",
      "",
      "        assertThat(result).isNotNull();",
      "        verify(repository).save(any());",
      "    }",
      "",
      "    @Test",
      "    @DisplayName(\"Should delete ${3}\")",
      "    void delete_Success() {",
      "        when(repository.existsById(1L)).thenReturn(true);",
      "",
      "        service.delete(1L);",
      "",
      "        verify(repository).deleteById(1L);",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_test_integration": {
    "prefix": "spring_test_integration",
    "description": "Integration Test with MockMvc",
    "body": [
      "package ${1:com.example.${2:app}}.controller;",
      "",
      "import ${1}.dto.${3:Entity}Dto;",
      "import com.fasterxml.jackson.databind.ObjectMapper;",
      "import org.junit.jupiter.api.Test;",
      "import org.junit.jupiter.api.DisplayName;",
      "import org.springframework.beans.factory.annotation.Autowired;",
      "import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;",
      "import org.springframework.boot.test.context.SpringBootTest;",
      "import org.springframework.http.MediaType;",
      "import org.springframework.test.context.ActiveProfiles;",
      "import org.springframework.test.web.servlet.MockMvc;",
      "",
      "import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*;",
      "import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;",
      "",
      "@SpringBootTest",
      "@AutoConfigureMockMvc",
      "@ActiveProfiles(\"test\")",
      "class ${TM_FILENAME_BASE} {",
      "",
      "    @Autowired",
      "    private MockMvc mockMvc;",
      "",
      "    @Autowired",
      "    private ObjectMapper objectMapper;",
      "",
      "    @Test",
      "    @DisplayName(\"GET /api/${4:entities} - Success\")",
      "    void getAll_Success() throws Exception {",
      "        mockMvc.perform(get(\"/api/${4}\"))",
      "                .andExpect(status().isOk())",
      "                .andExpect(content().contentType(MediaType.APPLICATION_JSON));",
      "    }",
      "",
      "    @Test",
      "    @DisplayName(\"GET /api/${4}/{id} - Success\")",
      "    void getById_Success() throws Exception {",
      "        mockMvc.perform(get(\"/api/${4}/1\"))",
      "                .andExpect(status().isOk())",
      "                .andExpect(jsonPath(\"$.id\").value(1));",
      "    }",
      "",
      "    @Test",
      "    @DisplayName(\"POST /api/${4} - Success\")",
      "    void create_Success() throws Exception {",
      "        ${3}Dto dto = new ${3}Dto();",
      "        // TODO: set dto fields",
      "",
      "        mockMvc.perform(post(\"/api/${4}\")",
      "                        .contentType(MediaType.APPLICATION_JSON)",
      "                        .content(objectMapper.writeValueAsString(dto)))",
      "                .andExpect(status().isCreated());",
      "    }",
      "",
      "    @Test",
      "    @DisplayName(\"DELETE /api/${4}/{id} - Success\")",
      "    void delete_Success() throws Exception {",
      "        mockMvc.perform(delete(\"/api/${4}/1\"))",
      "                .andExpect(status().isNoContent());",
      "    }",
      "}",
      "$0"
    ]
  },
