  "spring_dto_page": {
    "prefix": "spring_dto_page",
    "description": "Paginated Response DTO",
    "body": [
      "package ${1:com.example.${2:app}}.dto.response;",
      "",
      "import lombok.*;",
      "import java.util.List;",
      "",
      "@Data",
      "@Builder",
      "@NoArgsConstructor",
      "@AllArgsConstructor",
      "public class ${TM_FILENAME_BASE}<T> {",
      "",
      "    private List<T> content;",
      "    private int page;",
      "    private int size;",
      "    private long totalElements;",
      "    private int totalPages;",
      "    private boolean first;",
      "    private boolean last;",
      "",
      "    public static <T> ${TM_FILENAME_BASE}<T> of(org.springframework.data.domain.Page<T> page) {",
      "        return ${TM_FILENAME_BASE}.<T>builder()",
      "                .content(page.getContent())",
      "                .page(page.getNumber())",
      "                .size(page.getSize())",
      "                .totalElements(page.getTotalElements())",
      "                .totalPages(page.getTotalPages())",
      "                .first(page.isFirst())",
      "                .last(page.isLast())",
      "                .build();",
      "    }",
      "}",
      "$0"
    ]
  },
