  "spring_dto": {
    "prefix": "spring_dto",
    "description": "DTO class with validation",
    "body": [
      "package ${1:com.example.${2:app}}.dto;",
      "",
      "import jakarta.validation.constraints.*;",
      "import java.io.Serializable;",
      "import java.time.LocalDateTime;",
      "import java.util.Objects;",
      "",
      "public class ${TM_FILENAME_BASE} implements Serializable {",
      "",
      "    private Long id;",
      "",
      "    @NotBlank(message = \"${3:Name} is required\")",
      "    @Size(min = 2, max = 100, message = \"$3 must be between 2 and 100 characters\")",
      "    private String ${4:name};",
      "",
      "    private LocalDateTime createdAt;",
      "    private LocalDateTime updatedAt;",
      "",
      "    public ${TM_FILENAME_BASE}() {}",
      "",
      "    public ${TM_FILENAME_BASE}(Long id, String $4) {",
      "        this.id = id;",
      "        this.$4 = $4;",
      "    }",
      "",
      "    // Getters and Setters",
      "    public Long getId() { return id; }",
      "    public void setId(Long id) { this.id = id; }",
      "",
      "    public String get${4/(.*)/${1:/capitalize}/}() { return $4; }",
      "    public void set${4/(.*)/${1:/capitalize}/}(String $4) { this.$4 = $4; }",
      "",
      "    public LocalDateTime getCreatedAt() { return createdAt; }",
      "    public void setCreatedAt(LocalDateTime createdAt) { this.createdAt = createdAt; }",
      "",
      "    public LocalDateTime getUpdatedAt() { return updatedAt; }",
      "    public void setUpdatedAt(LocalDateTime updatedAt) { this.updatedAt = updatedAt; }",
      "",
      "    @Override",
      "    public boolean equals(Object o) {",
      "        if (this == o) return true;",
      "        if (o == null || getClass() != o.getClass()) return false;",
      "        ${TM_FILENAME_BASE} that = (${TM_FILENAME_BASE}) o;",
      "        return Objects.equals(id, that.id);",
      "    }",
      "",
      "    @Override",
      "    public int hashCode() { return Objects.hash(id); }",
      "}",
      "$0"
    ]
  },
