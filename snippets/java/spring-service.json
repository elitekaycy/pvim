{
  "spring_service": {
    "prefix": "spring_service",
    "description": "Service with CRUD",
    "body": [
      "package ${1:com.example.${2:app}}.service;",
      "",
      "import ${1}.dto.${3:Entity}Dto;",
      "import ${1}.entity.${3};",
      "import ${1}.mapper.${3}Mapper;",
      "import ${1}.repository.${3}Repository;",
      "import ${1}.exception.ResourceNotFoundException;",
      "import org.springframework.stereotype.Service;",
      "import org.springframework.transaction.annotation.Transactional;",
      "",
      "import java.util.List;",
      "",
      "@Service",
      "@Transactional",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    private final ${3}Repository repository;",
      "    private final ${3}Mapper mapper;",
      "",
      "    public ${TM_FILENAME_BASE}(${3}Repository repository, ${3}Mapper mapper) {",
      "        this.repository = repository;",
      "        this.mapper = mapper;",
      "    }",
      "",
      "    @Transactional(readOnly = true)",
      "    public List<${3}Dto> findAll() {",
      "        return repository.findAll().stream().map(mapper::toDto).toList();",
      "    }",
      "",
      "    @Transactional(readOnly = true)",
      "    public ${3}Dto findById(Long id) {",
      "        return repository.findById(id)",
      "                .map(mapper::toDto)",
      "                .orElseThrow(() -> new ResourceNotFoundException(\"${3} not found: \" + id));",
      "    }",
      "",
      "    public ${3}Dto create(${3}Dto dto) {",
      "        ${3} entity = mapper.toEntity(dto);",
      "        return mapper.toDto(repository.save(entity));",
      "    }",
      "",
      "    public ${3}Dto update(Long id, ${3}Dto dto) {",
      "        ${3} entity = repository.findById(id)",
      "                .orElseThrow(() -> new ResourceNotFoundException(\"${3} not found: \" + id));",
      "        mapper.updateEntity(dto, entity);",
      "        return mapper.toDto(repository.save(entity));",
      "    }",
      "",
      "    public void delete(Long id) {",
      "        if (!repository.existsById(id)) {",
      "            throw new ResourceNotFoundException(\"${3} not found: \" + id);",
      "        }",
      "        repository.deleteById(id);",
      "    }",
      "}",
      "$0"
    ]
  },
  "spring_service_lombok": {
    "prefix": "spring_service_lombok",
    "description": "Service with Lombok",
    "body": [
      "package ${1:com.example.${2:app}}.service;",
      "",
      "import ${1}.dto.${3:Entity}Dto;",
      "import ${1}.entity.${3};",
      "import ${1}.mapper.${3}Mapper;",
      "import ${1}.repository.${3}Repository;",
      "import ${1}.exception.ResourceNotFoundException;",
      "import lombok.RequiredArgsConstructor;",
      "import lombok.extern.slf4j.Slf4j;",
      "import org.springframework.stereotype.Service;",
      "import org.springframework.transaction.annotation.Transactional;",
      "",
      "import java.util.List;",
      "",
      "@Slf4j",
      "@Service",
      "@Transactional",
      "@RequiredArgsConstructor",
      "public class ${TM_FILENAME_BASE} {",
      "",
      "    private final ${3}Repository repository;",
      "    private final ${3}Mapper mapper;",
      "",
      "    @Transactional(readOnly = true)",
      "    public List<${3}Dto> findAll() {",
      "        log.debug(\"Finding all ${3}s\");",
      "        return repository.findAll().stream().map(mapper::toDto).toList();",
      "    }",
      "",
      "    @Transactional(readOnly = true)",
      "    public ${3}Dto findById(Long id) {",
      "        log.debug(\"Finding ${3} by id: {}\", id);",
      "        return repository.findById(id)",
      "                .map(mapper::toDto)",
      "                .orElseThrow(() -> new ResourceNotFoundException(\"${3} not found: \" + id));",
      "    }",
      "",
      "    public ${3}Dto create(${3}Dto dto) {",
      "        log.info(\"Creating ${3}\");",
      "        ${3} entity = mapper.toEntity(dto);",
      "        return mapper.toDto(repository.save(entity));",
      "    }",
      "",
      "    public ${3}Dto update(Long id, ${3}Dto dto) {",
      "        log.info(\"Updating ${3}: {}\", id);",
      "        ${3} entity = repository.findById(id)",
      "                .orElseThrow(() -> new ResourceNotFoundException(\"${3} not found: \" + id));",
      "        mapper.updateEntity(dto, entity);",
      "        return mapper.toDto(repository.save(entity));",
      "    }",
      "",
      "    public void delete(Long id) {",
      "        log.info(\"Deleting ${3}: {}\", id);",
      "        if (!repository.existsById(id)) {",
      "            throw new ResourceNotFoundException(\"${3} not found: \" + id);",
      "        }",
      "        repository.deleteById(id);",
      "    }",
      "}",
      "$0"
    ]
  },
