{
  "spring_datasource": {
    "prefix": "spring_datasource",
    "description": "Spring datasource configuration",
    "body": [
      "spring:",
      "  datasource:",
      "    url: jdbc:${1|postgresql,mysql,h2|}://${2:localhost}:${3:5432}/${4:database}",
      "    username: ${5:username}",
      "    password: ${6:password}",
      "    driver-class-name: ${7:org.postgresql.Driver}",
      "    hikari:",
      "      maximum-pool-size: 10",
      "      minimum-idle: 5",
      "      idle-timeout: 30000",
      "      connection-timeout: 20000",
      "$0"
    ]
  },
  "spring_jpa": {
    "prefix": "spring_jpa",
    "description": "Spring JPA configuration",
    "body": [
      "spring:",
      "  jpa:",
      "    hibernate:",
      "      ddl-auto: ${1|update,create,create-drop,validate,none|}",
      "    show-sql: ${2|true,false|}",
      "    properties:",
      "      hibernate:",
      "        format_sql: true",
      "        dialect: ${3:org.hibernate.dialect.PostgreSQLDialect}",
      "        jdbc:",
      "          batch_size: 50",
      "        order_inserts: true",
      "        order_updates: true",
      "$0"
    ]
  },
  "spring_security_jwt": {
    "prefix": "spring_security_jwt",
    "description": "JWT security configuration",
    "body": [
      "jwt:",
      "  secret: ${1:your-secret-key-min-256-bits}",
      "  expiration: ${2:86400000}  # 24 hours",
      "  refresh-expiration: ${3:604800000}  # 7 days",
      "  issuer: ${4:your-app-name}",
      "$0"
    ]
  },
  "spring_logging": {
    "prefix": "spring_logging",
    "description": "Logging configuration",
    "body": [
      "logging:",
      "  level:",
      "    root: ${1|INFO,DEBUG,WARN,ERROR|}",
      "    ${2:com.example}: ${3|DEBUG,INFO,WARN|}",
      "    org.hibernate.SQL: ${4|DEBUG,INFO|}",
      "    org.hibernate.type.descriptor.sql: ${5|TRACE,DEBUG|}",
      "  pattern:",
      "    console: \"%d{yyyy-MM-dd HH:mm:ss} - %msg%n\"",
      "  file:",
      "    name: logs/application.log",
      "$0"
    ]
  },
  "spring_actuator": {
    "prefix": "spring_actuator",
    "description": "Actuator configuration",
    "body": [
      "management:",
      "  endpoints:",
      "    web:",
      "      exposure:",
      "        include: ${1|health,info,metrics,prometheus,\"*\"|}",
      "      base-path: /actuator",
      "  endpoint:",
      "    health:",
      "      show-details: ${2|always,when_authorized,never|}",
      "  metrics:",
      "    export:",
      "      prometheus:",
      "        enabled: true",
      "$0"
    ]
  },
  "spring_cache_redis": {
    "prefix": "spring_cache_redis",
    "description": "Redis cache configuration",
    "body": [
      "spring:",
      "  cache:",
      "    type: redis",
      "  redis:",
      "    host: ${1:localhost}",
      "    port: ${2:6379}",
      "    password: ${3:}",
      "    timeout: 60000",
      "    lettuce:",
      "      pool:",
      "        max-active: 8",
      "        max-idle: 8",
      "        min-idle: 0",
      "$0"
    ]
  },
  "spring_kafka": {
    "prefix": "spring_kafka",
    "description": "Kafka configuration",
    "body": [
      "spring:",
      "  kafka:",
      "    bootstrap-servers: ${1:localhost:9092}",
      "    consumer:",
      "      group-id: ${2:my-group}",
      "      auto-offset-reset: ${3|earliest,latest|}",
      "      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer",
      "      value-deserializer: org.apache.kafka.common.serialization.StringDeserializer",
      "    producer:",
      "      key-serializer: org.apache.kafka.common.serialization.StringSerializer",
      "      value-serializer: org.apache.kafka.common.serialization.StringSerializer",
      "$0"
    ]
  },
  "spring_profile": {
    "prefix": "spring_profile",
    "description": "Profile-specific configuration",
    "body": [
      "---",
      "spring:",
      "  config:",
      "    activate:",
      "      on-profile: ${1|dev,prod,test,local|}",
      "",
      "$0"
    ]
  },
  "spring_flyway": {
    "prefix": "spring_flyway",
    "description": "Flyway migration configuration",
    "body": [
      "spring:",
      "  flyway:",
      "    enabled: true",
      "    locations: classpath:db/migration",
      "    baseline-on-migrate: true",
      "    baseline-version: 0",
      "    validate-on-migrate: true",
      "$0"
    ]
  },
  "spring_mail": {
    "prefix": "spring_mail",
    "description": "Mail configuration",
    "body": [
      "spring:",
      "  mail:",
      "    host: ${1:smtp.gmail.com}",
      "    port: ${2:587}",
      "    username: ${3:your-email@gmail.com}",
      "    password: ${4:your-app-password}",
      "    properties:",
      "      mail:",
      "        smtp:",
      "          auth: true",
      "          starttls:",
      "            enable: true",
      "$0"
    ]
  },
  "spring_openapi": {
    "prefix": "spring_openapi",
    "description": "OpenAPI/Swagger configuration",
    "body": [
      "springdoc:",
      "  api-docs:",
      "    path: /api-docs",
      "  swagger-ui:",
      "    path: /swagger-ui.html",
      "    operationsSorter: method",
      "    tagsSorter: alpha",
      "  show-actuator: true",
      "$0"
    ]
  },
  "spring_docker_compose": {
    "prefix": "spring_docker_compose",
    "description": "Docker Compose for Spring Boot with PostgreSQL & Redis",
    "body": [
      "version: '3.8'",
      "",
      "services:",
      "  ${1:app}:",
      "    build:",
      "      context: .",
      "      dockerfile: Dockerfile",
      "    ports:",
      "      - \"${2:8080}:8080\"",
      "    environment:",
      "      - SPRING_PROFILES_ACTIVE=${3:dev}",
      "      - SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/${4:appdb}",
      "      - SPRING_DATASOURCE_USERNAME=${5:postgres}",
      "      - SPRING_DATASOURCE_PASSWORD=${6:postgres}",
      "      - SPRING_REDIS_HOST=redis",
      "    depends_on:",
      "      db:",
      "        condition: service_healthy",
      "      redis:",
      "        condition: service_started",
      "    networks:",
      "      - app-network",
      "",
      "  db:",
      "    image: postgres:${7:16}-alpine",
      "    environment:",
      "      - POSTGRES_DB=${4}",
      "      - POSTGRES_USER=${5}",
      "      - POSTGRES_PASSWORD=${6}",
      "    volumes:",
      "      - postgres-data:/var/lib/postgresql/data",
      "    ports:",
      "      - \"5432:5432\"",
      "    healthcheck:",
      "      test: [\"CMD-SHELL\", \"pg_isready -U ${5}\"]",
      "      interval: 10s",
      "      timeout: 5s",
      "      retries: 5",
      "    networks:",
      "      - app-network",
      "",
      "  redis:",
      "    image: redis:7-alpine",
      "    ports:",
      "      - \"6379:6379\"",
      "    volumes:",
      "      - redis-data:/data",
      "    networks:",
      "      - app-network",
      "",
      "volumes:",
      "  postgres-data:",
      "  redis-data:",
      "",
      "networks:",
      "  app-network:",
      "    driver: bridge",
      "$0"
    ]
  },
  "spring_docker_compose_kafka": {
    "prefix": "spring_docker_compose_kafka",
    "description": "Docker Compose with Kafka",
    "body": [
      "  zookeeper:",
      "    image: confluentinc/cp-zookeeper:7.5.0",
      "    environment:",
      "      ZOOKEEPER_CLIENT_PORT: 2181",
      "      ZOOKEEPER_TICK_TIME: 2000",
      "    ports:",
      "      - \"2181:2181\"",
      "    networks:",
      "      - app-network",
      "",
      "  kafka:",
      "    image: confluentinc/cp-kafka:7.5.0",
      "    depends_on:",
      "      - zookeeper",
      "    ports:",
      "      - \"9092:9092\"",
      "    environment:",
      "      KAFKA_BROKER_ID: 1",
      "      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181",
      "      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092",
      "      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT",
      "      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT",
      "      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1",
      "    networks:",
      "      - app-network",
      "$0"
    ]
  },
  "spring_docker_compose_mysql": {
    "prefix": "spring_docker_compose_mysql",
    "description": "Docker Compose with MySQL",
    "body": [
      "  mysql:",
      "    image: mysql:8.0",
      "    environment:",
      "      - MYSQL_DATABASE=${1:appdb}",
      "      - MYSQL_ROOT_PASSWORD=${2:root}",
      "      - MYSQL_USER=${3:app}",
      "      - MYSQL_PASSWORD=${4:password}",
      "    volumes:",
      "      - mysql-data:/var/lib/mysql",
      "    ports:",
      "      - \"3306:3306\"",
      "    healthcheck:",
      "      test: [\"CMD\", \"mysqladmin\", \"ping\", \"-h\", \"localhost\"]",
      "      interval: 10s",
      "      timeout: 5s",
      "      retries: 5",
      "    networks:",
      "      - app-network",
      "$0"
    ]
  },
  "spring_docker_compose_mongo": {
    "prefix": "spring_docker_compose_mongo",
    "description": "Docker Compose with MongoDB",
    "body": [
      "  mongodb:",
      "    image: mongo:7.0",
      "    environment:",
      "      - MONGO_INITDB_ROOT_USERNAME=${1:root}",
      "      - MONGO_INITDB_ROOT_PASSWORD=${2:password}",
      "      - MONGO_INITDB_DATABASE=${3:appdb}",
      "    volumes:",
      "      - mongo-data:/data/db",
      "    ports:",
      "      - \"27017:27017\"",
      "    networks:",
      "      - app-network",
      "$0"
    ]
  }
}
